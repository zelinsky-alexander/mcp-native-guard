{
  "version": 6,
  "cmakeMinimumRequired": {"major": 3, "minor": 24, "patch": 0},
  "configurePresets": [
    {
      "name": "base",
      "hidden": true,
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/build/${presetName}",
      "cacheVariables": {"CMAKE_EXPORT_COMPILE_COMMANDS": "ON"}
    },
    {
      "name": "dev-debug",
      "inherits": "base",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug",
        "MNG_BUILD_TESTS": "ON",
        "MNG_BUILD_BENCHMARKS": "OFF"
      }
    },
    {
      "name": "asan",
      "inherits": "dev-debug",
      "cacheVariables": {"MNG_ENABLE_SANITIZERS": "ON"}
    },
    {
      "name": "perf",
      "inherits": "base",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release",
        "MNG_BUILD_TESTS": "OFF",
        "MNG_BUILD_BENCHMARKS": "ON",
        "MNG_ENABLE_LTO": "ON"
      }
    }
  ],
  "buildPresets": [
    {"name": "dev-debug", "configurePreset": "dev-debug"},
    {"name": "asan", "configurePreset": "asan"},
    {"name": "perf", "configurePreset": "perf"}
  ],
  "testPresets": [
    {"name": "dev-debug", "configurePreset": "dev-debug", "output": {"outputOnFailure": true}},
    {"name": "asan", "configurePreset": "asan", "output": {"outputOnFailure": true}}
  ]
}
